# URL do relay WebSocket.
# Em LAN: usa a porta do Vite (proxy interno) — não precisa abrir porta extra no firewall.
# Exemplo LAN: VITE_WS_URL=ws://192.168.1.10:5173
# Exemplo deploy (Railway/Render com servidor separado): VITE_WS_URL=wss://football-sim-relay.up.railway.app
# Sem esta variável: usa BroadcastChannel (só funciona na mesma aba do navegador).
VITE_WS_URL=
